{
  "name": "claude-code-clone",
  "version": "1.0.0",
  "description": "A TypeScript AI coding agent inspired by Claude Code architecture",
  "type": "module",
  "main": "dist/entrypoints/cli.js",
  "bin": {
    "cc-agent": "dist/entrypoints/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/entrypoints/cli.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "ci": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-spinners": "^3.2.0",
    "conf": "^13.1.0",
    "diff": "^9.0.0",
    "execa": "^9.5.2",
    "glob": "^11.0.1",
    "ignore": "^7.0.3",
    "ink": "^5.2.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lockfile": "^1.0.4",
    "meow": "^13.2.0",
    "ora": "^8.2.0",
    "p-limit": "^6.2.0",
    "p-map": "^7.0.3",
    "react": "^18.3.1",
    "strip-ansi": "^7.1.0",
    "tree-sitter": "^0.22.4",
    "wrap-ansi": "^9.0.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/lockfile": "^1.0.4",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.20",
    "eslint": "^9.25.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
